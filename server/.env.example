# 서버 설정
PORT=8080

# DB 설정 (1단계: sqlite, 2단계: postgres)
DB_TYPE=sqlite
DB_PATH=data/app.db

# PostgreSQL 전환 시 아래 주석 해제
# DB_TYPE=postgres
# DB_DSN=postgres://user:password@localhost:5432/customer_support?sslmode=disable

# JWT 시크릿 (운영 시 반드시 변경)
JWT_SECRET=change-this-secret-in-production

# 환경 (development / production)
APP_ENV=development
